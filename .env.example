# URL situs (untuk sitemap, RSS, OG)
# FIX 2026-06-12: Production URL. Saat ini Vercel default subdomain (no custom domain).
# Override ini di Vercel dashboard → Settings → Environment Variables kalau beli domain nanti.
NEXT_PUBLIC_SITE_URL=https://www.wawasanai.com

# Analytics — Vercel Web Analytics (gratis di Hobby plan)
# Aktifkan di Vercel dashboard → project → tab Analytics & Speed Insights.
# Tidak perlu env var; paket @vercel/analytics sudah terpasang di layout.

# Newsletter via Resend (opsional — tanpa ini mode demo lokal)
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Admin dashboard (/admin) — sementara sampai Supabase Auth aktif
ADMIN_EMAILS=fajar.mreza@gmail.com
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
